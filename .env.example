# ---- Jira (Cloud) ----
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=YOUR_JIRA_API_TOKEN
# Optionnel (utile si tu veux créer des tickets)
JIRA_PROJECT_KEY=PROJ

# ---- GitHub ----
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=org/repo

# ---- Advanced LLM (planning / reasoning / critique) ----
ADVANCED_PROVIDER=openai
ADVANCED_API_KEY=sk-proj-xxx
ADVANCED_MODEL_NAME=gpt-4.1-mini
ADVANCED_BASE_URL=
# Backward compatibility if needed:
# OPENAI_API_KEY=sk-proj-xxx

# ---- Local LLM via Ollama (drafting / formatting / extraction) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Behaviour ----
# DRY_RUN=true/false par défaut (CLI override)
DRY_RUN=true
